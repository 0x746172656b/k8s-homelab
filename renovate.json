{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)helm-release\\.yaml$"],
      "matchStrings": [
        "repository:\\s*(?<depName>ghcr\\.io/[^\\s\\n]+)\\s*\\n\\s*tag:\\s*(?<currentValue>[^\\s\\n]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
